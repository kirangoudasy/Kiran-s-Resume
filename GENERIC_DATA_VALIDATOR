onDeleteRow: function (oEvent) {

  const oItem = oEvent.getSource().getParent(); // ColumnListItem
  const oContext = oItem.getBindingContext("columnsModel");

  const oModel = this.getView().getModel("columnsModel");
  const aData = oModel.getProperty("/columns");

  const iIndex = oContext.getPath().split("/")[2];

  // Optional confirmation (remove if you don’t want popup)
  sap.m.MessageBox.confirm("Delete this column?", {
    onClose: (action) => {
      if (action === "OK") {
        aData.splice(iIndex, 1);
        oModel.setProperty("/columns", aData);
      }
    }
  });

}
