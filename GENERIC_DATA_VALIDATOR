srv.on("UpdateTemplate", async (req) => {

  const { TemplateStorage, LoadMap } = srv.entities;
  const { id, JSON_TEMPLATE, status } = req.data;

  const tx = cds.transaction(req);

  // get existing row
  const result = await tx.read(TemplateStorage).where({ ID: id });

  if (!result || !result.length) {
    return req.error(404, "Template not found");
  }

  const row = result[0];

  // ✅ update template JSON + status
  await tx.update(TemplateStorage)
    .set({
      JSON_TEMPLATE: JSON_TEMPLATE,
      STATUS: status
    })
    .where({ ID: id });

  // (optional but recommended — same pattern you used above)
  // delete old LoadMap entries
  await tx.delete(LoadMap).where({
    MODULE_NAME: row.MODULE_NAME,
    SUB_MODULE_NAME: row.SUB_MODULE_NAME,
    LOAD_TEMPLATE: row.LOAD_TEMPLATE
  });

  return "Template updated successfully";
});
