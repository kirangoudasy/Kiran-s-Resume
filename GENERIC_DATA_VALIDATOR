onEditPress: async function () {

  const oTable = this.byId("templateDashTable");
  const aSelectedIndices = oTable.getSelectedIndices();

  if (aSelectedIndices.length !== 1) {
    sap.m.MessageToast.show("Please select only one row");
    return;
  }

  const oRowData = oTable.getContextByIndex(aSelectedIndices[0]).getObject();

  // ❌ BLOCK REJECTED
  if (oRowData.STATUS === "rejected") {
    sap.m.MessageToast.show("Cannot edit rejected template");
    return;
  }

  // ✅ Set expiry model
  const oEditModel = new sap.ui.model.json.JSONModel({
    expiryDate: oRowData.EXPIRY_DATE,
    templateId: oRowData.ID
  });
  this.getView().setModel(oEditModel, "editModel");

  // ✅ Parse template JSON
  let columnsData = oRowData.JSON_TEMPLATE;

  if (typeof columnsData === "string") {
    columnsData = JSON.parse(columnsData);
  }

  // ✅ Convert to UI format (columnsModel)
  let formatted = columnsData.map(col => {

    let length = "";
    let scale = "";

    if (col.DATA_TYPE.includes("(")) {
      let inside = col.DATA_TYPE.split("(")[1].replace(")", "");
      let parts = inside.split(",");
      length = parts[0];
      scale = parts[1] || "";
    }

    return {
      COLUMN_NAME: col.COLUMN_NAME,
      DATATYPE: col.DATA_TYPE.split("(")[0],
      LENGTH_PRECISION: length,
      SCALE: scale,
      CONSTRAINTS: col.CONSTRAINTS || "NULL"
    };
  });

  this.getView().setModel(new sap.ui.model.json.JSONModel({
    columns: formatted
  }), "columnsModel");

  // open dialog
  if (!this._oEditExpiryDialog) {
    this._oEditExpiryDialog = await sap.ui.core.Fragment.load({
      id: this.getView().getId(),
      name: "fileuploader.view.fragment.EditExpiry",
      controller: this
    });
    this.getView().addDependent(this._oEditExpiryDialog);
  }

  this._oEditExpiryDialog.open();
}


onSubmitEdit: async function () {

  const columns = this.getView().getModel("columnsModel").getData().columns;
  const editData = this.getView().getModel("editModel").getData();

  // convert UI → backend format
  let payloadColumns = columns.map(col => {

    let dataType = col.DATATYPE;

    if (col.DATATYPE === "NVARCHAR") {
      dataType += `(${col.LENGTH_PRECISION || 1})`;
    } 
    else if (col.DATATYPE === "DECIMAL") {
      dataType += `(${col.LENGTH_PRECISION || 1},${col.SCALE || 0})`;
    }

    return {
      COLUMN_NAME: col.COLUMN_NAME,
      DATA_TYPE: dataType,
      CONSTRAINTS: col.CONSTRAINTS
    };
  });

  const payload = {
    ID: editData.templateId,
    JSON_TEMPLATE: JSON.stringify(payloadColumns),
    EXPIRY_DATE: editData.expiryDate,
    STATUS: "pending"   // 🔥 IMPORTANT
  };

  try {

    const oModel = this.getOwnerComponent().getModel();
    const oFunction = oModel.bindContext("/UpdateTemplate(...)");

    oFunction.setParameter("payload", JSON.stringify(payload));

    await oFunction.execute();

    sap.m.MessageToast.show("Template updated");

    this._oEditExpiryDialog.close();

    this.byId("templateDashTable").getBinding("rows").refresh();

  } catch (e) {
    console.error(e);
    sap.m.MessageToast.show("Error updating template");
  }
}




