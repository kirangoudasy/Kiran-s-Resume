<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">

    <Dialog id="editExpiryDialog" title="Edit Template" draggable="true" resizable="true" contentWidth="800px">

        <content>

            <IconTabBar>

                <items>

                    <!-- TAB 1: Edit Expiry Date (EXISTING) -->
                    <IconTabFilter text="Edit Expiry Date">

                        <VBox class="sapUiSmallMargin">
                            <Label text="New Expiry Date"/>
                            <DatePicker 
                                valueFormat="yyyy-MM-dd" 
                                displayFormat="long" 
                                required="true"
                                value="{editModel>/expiryDate}" />
                        </VBox>

                    </IconTabFilter>

                    <!-- TAB 2: Edit Template (NEW) -->
                    <IconTabFilter text="Edit Template">

                        <VBox class="sapUiSmallMargin">

                            <Table items="{columnsModel>/columns}">

                                <cells>
                                    <Input value="{columnsModel>COLUMN_NAME}"/>

                                    <Input value="{columnsModel>DATATYPE}"/>

                                    <Input value="{columnsModel>CONSTRAINTS}"/>

                                    <Button 
                                        icon="sap-icon://delete"
                                        type="Transparent"
                                        press=".onDeleteRow"/>
                                </cells>

                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Input value="{columnsModel>COLUMN_NAME}"/>
                                            <Input value="{columnsModel>DATA_TYPE}"/>
                                            <Input value="{columnsModel>CONSTRAINTS}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>

                            </Table>

                            <HBox class="sapUiSmallMarginTop">
                                <Button text="Add Column" press=".onAddColumn"/>
                                <Button text="Submit" type="Emphasized" press=".onSubmitEdit"/>
                            </HBox>

                        </VBox>

                    </IconTabFilter>

                </items>

            </IconTabBar>

        </content>

        <!-- EXISTING BUTTONS (UNCHANGED) -->
        <beginButton>
            <Button text="save" press=".onEditExpirySave" />
        </beginButton>

        <endButton>
            <Button text="Cancel" press=".onEditExpiryCancel" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>
