<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">

    <Dialog title="Edit Template" draggable="true" resizable="true" contentWidth="800px">

        <content>

            <IconTabBar>

                <items>

                    <!-- TAB 1: Edit Expiry Date -->
                    <IconTabFilter text="Edit Expiry Date" key="expiry">

                        <VBox class="sapUiSmallMargin">
                            <Label text="New Expiry Date"/>
                            <DatePicker 
                                valueFormat="yyyy-MM-dd" 
                                displayFormat="long" 
                                required="true"
                                value="{editModel>/expiryDate}" />
                        </VBox>

                    </IconTabFilter>

                    <!-- TAB 2: Edit Template -->
                    <IconTabFilter text="Edit Template" key="template">

                        <VBox class="sapUiSmallMargin">

                            <Table items="{columnsModel>/columns}" class="sapUiSizeCompact">

                                <columns>
                                    <Column><Text text="Column Name"/></Column>
                                    <Column><Text text="Data Type"/></Column>
                                    <Column><Text text="Length / Precision"/></Column>
                                    <Column><Text text="Scale"/></Column>
                                    <Column><Text text="Constraints"/></Column>
                                    <Column width="3rem"/>
                                </columns>

                                <items>
                                    <ColumnListItem>
                                        <cells>

                                            <!-- Column Name -->
                                            <Input value="{columnsModel>COLUMN_NAME}" liveChange=".onColumnNameChange"/>

                                            <!-- Data Type -->
                                            <Select selectedKey="{columnsModel>DATATYPE}" change=".onDataTypeChange">
                                                <items>
                                                    <core:Item key="NVARCHAR" text="NVARCHAR"/>
                                                    <core:Item key="TIMESTAMP" text="TIMESTAMP"/>
                                                    <core:Item key="DECIMAL" text="DECIMAL"/>
                                                    <core:Item key="DATE" text="DATE"/>
                                                    <core:Item key="TIME" text="TIME"/>
                                                </items>
                                            </Select>

                                            <!-- Length -->
                                            <StepInput 
                                                value="{columnsModel>LENGTH_PRECISION}" 
                                                min="1"
                                                max="1000"
                                                enabled="{= ${columnsModel>DATATYPE} === 'NVARCHAR' || ${columnsModel>DATATYPE} === 'DECIMAL'}"/>

                                            <!-- Scale -->
                                            <StepInput 
                                                value="{columnsModel>SCALE}" 
                                                min="0"
                                                max="38"
                                                enabled="{= ${columnsModel>DATATYPE} === 'DECIMAL'}"/>

                                            <!-- Constraints -->
                                            <Select selectedKey="{columnsModel>CONSTRAINTS}">
                                                <items>
                                                    <core:Item key="NULL" text="NULL"/>
                                                    <core:Item key="NOT NULL" text="NOT NULL"/>
                                                </items>
                                            </Select>

                                            <!-- Delete -->
                                            <Button 
                                                icon="sap-icon://delete"
                                                type="Transparent"
                                                press=".onDeleteRow"/>

                                        </cells>
                                    </ColumnListItem>
                                </items>

                            </Table>

                            <HBox class="sapUiSmallMarginTop">
                                <Button text="Add Column" press=".onAddColumn"/>
                                
                            </HBox>

                        </VBox>

                    </IconTabFilter>

                </items>

            </IconTabBar>

        </content>

        <!-- EXISTING BUTTONS -->
        <beginButton>
        <Button 
        text="Save Expiry" 
        visible="{= ${editTabBar>/selectedKey} === 'expiry' }"
        press=".onSaveExpirySeparate" />
        </beginButton>

        <customFooter>
            <Toolbar>
                <ToolbarSpacer/>
                <Button 
                    text="Save Template" 
                    type="Emphasized"
                    visible="{= ${editTabBar>/selectedKey} === 'template' }"
                    press=".onSaveTemplateSeparate"/>
                <Button text="Cancel" press=".onEditExpiryCancel"/>
            </Toolbar>
        </customFooter>

        <endButton>
            <Button text="Cancel" press=".onEditExpiryCancel" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>
