<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Dialog id="editExpiryDialog" title="Edit Expiry Date" draggable="true" resizable="true">
        <VBox id="vbox" class="sapUiSmallMargin">
            <Label id="label" text="New Expiry Date"/>
            <DatePicker id="editExpiryDatePicker" valueFormat="yyyy-MM-dd" displayFormat="long" required="true" />
        </VBox>
        <beginButton><Button id="btn1" text="save" press=".onEditExpirySave" /></beginButton>
        <endButton><Button id="btn2" text="Cancel" press=".onEditExpiryCancel" /></endButton>
    </Dialog>
</core:FragmentDefinition>
